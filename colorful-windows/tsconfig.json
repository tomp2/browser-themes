{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["DOM", "ES2020"],
        "strict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
